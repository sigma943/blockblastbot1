<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 Block Blast Bot"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IMMORTAL AI"
        android:textSize="14sp"
        android:textColor="#10B981"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bot wyłączony"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvMoves"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ruchy: 0"
        android:textSize="16sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="▶ START BOT"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#10B981"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:text="⚙ Włącz dostępność"
        android:textSize="14sp"
        android:backgroundTint="#374151"
        android:textColor="#ffffff"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Włącz dostępność powyżej&#10;2. Otwórz Block Blast&#10;3. Naciśnij START BOT"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"/>

</LinearLayout>
